<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/fitness_bg_navy"
    android:padding="@dimen/spacing_large">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Create Routine"
        style="@style/TextAppearanceFitnessScreenTitle"
        android:layout_marginBottom="@dimen/spacing_large" />

    <FrameLayout
        style="@style/Widget.Fitness.Card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/spacing_large">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_medium">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ROUTINE NAME"
                style="@style/TextAppearanceFitnessCardEyebrow"
                android:layout_marginBottom="@dimen/spacing_small" />

            <EditText
                android:id="@+id/etRoutineName"
                style="@style/Widget.Fitness.EditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="e.g. Push Day, Full Body"
                android:inputType="textCapWords" />
        </LinearLayout>
    </FrameLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="EXERCISES"
                style="@style/TextAppearanceFitnessCardEyebrow"
                android:layout_marginBottom="@dimen/spacing_medium" />

            <LinearLayout
                android:id="@+id/containerExercises"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <!-- Items injected here -->
            </LinearLayout>

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnAddExercise"
                style="@style/Widget.Fitness.Button.Secondary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_medium"
                android:text="Add Exercise" />

        </LinearLayout>
    </ScrollView>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnSaveRoutine"
        style="@style/Widget.Fitness.Button.Primary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_large"
        android:text="Save Routine" />

</LinearLayout>

